            }
        }

        if ((instanceRow.faces || []).length > 0 && pts.length >= 3) {
            ctx.save()
            ctx.beginPath()
            var started = false
            for (var fpi = 0; fpi < pts.length; fpi++) {
                var fp = pointMap[pts[fpi].id]
                if (!fp) {
                    continue
                }
                if (!started) {
                    ctx.moveTo(fp.x, fp.y)
                    started = true
                } else {
                    ctx.lineTo(fp.x, fp.y)
                }
            }
            if (started) {
                ctx.closePath()
                ctx.fillStyle = isActive ? "rgba(37, 99, 235, 0.18)" : "rgba(148, 163, 184, 0.16)"
