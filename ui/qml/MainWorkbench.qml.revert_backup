        ctx.lineWidth = isActive ? 3 : 2
        for (var e = 0; e < edges.length; e++) {
            var edge = edges[e]
            var a = pointMap[edge.start_point_id]
            var b = pointMap[edge.end_point_id]
            if (!a || !b) {
